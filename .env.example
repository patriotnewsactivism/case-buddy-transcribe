# Copy to .env for local dev (Vite only exposes VITE_-prefixed vars to the client).
# NEVER commit real values here — this repo is public.

# Primary transcription engine (FFmpeg preprocessing + Deepgram Nova-3).
# Get a key at https://console.deepgram.com/
VITE_DEEPGRAM_API_KEY=

# Secondary transcription engine (same FFmpeg pipeline, Whisper Large v3).
# Used automatically if Deepgram is unconfigured or its request fails.
# Get a key at https://console.groq.com/keys
VITE_GROQ_API_KEY=

# Final fallback transcription engine (used automatically if Deepgram and Groq
# are both missing/fail). Also the only engine with summary/key-fact extraction.
VITE_GEMINI_API_KEY=

VITE_ASSEMBLYAI_API_KEY=
VITE_GOOGLE_CLIENT_ID=
