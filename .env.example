# Copy to .env for local dev (Vite only exposes VITE_-prefixed vars to the client).
# NEVER commit real values here — this repo is public.

# Primary transcription engine (FFmpeg preprocessing + Deepgram Nova-3).
# Get a key at https://console.deepgram.com/
VITE_DEEPGRAM_API_KEY=

# Secondary transcription engine (same FFmpeg pipeline, Whisper Large v3).
# Used automatically if Deepgram is unconfigured or its request fails.
# Get a key at https://console.groq.com/keys
VITE_GROQ_API_KEY=

# Not used for transcription (Deepgram/Groq only, see transcriptionService.ts).
# Kept for other Gemini-powered utilities (see services/geminiService.ts).
VITE_GEMINI_API_KEY=

VITE_ASSEMBLYAI_API_KEY=
VITE_GOOGLE_CLIENT_ID=

# Shared case-companion Supabase project (also used by case-companion,
# DiscoveryLens, and AI-Law-Partner). Enables the "Sync to Case" panel on a
# completed transcript, which writes into the shared `documents` table via
# the transcribe-app-sync Edge Function. Leave both empty to hide the panel.
VITE_SUPABASE_URL=https://jpzkumgndqsdwimbvjku.supabase.co
VITE_SUPABASE_ANON_KEY=
